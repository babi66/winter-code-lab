                        <div class="grid gap-6">
                            <div>
                                <label class="block text-slate-600 dark:text-slate-500 text-[10px] font-black uppercase tracking-[0.3em] mb-3 ml-1" id="white">Full Name</label>
                                <input 
                                    type="text" 
                                    name="name" 
                                    required 
                                    placeholder="Tebarek Mohammed" 
                                    class="w-full bg-white dark:bg-slate-800/30 border border-slate-200 dark:border-slate-800 rounded-2xl px-6 py-5 text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-slate-700 focus:border-emerald-500/50 outline-none transition-all shadow-sm dark:shadow-none" 
