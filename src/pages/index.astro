                                    <select 
                                        name="grade" 
                                        class="w-full bg-white dark:bg-slate-800/30 border border-slate-200 dark:border-slate-800 rounded-2xl px-6 py-5 text-slate-900 dark:text-white focus:border-emerald-500/50 outline-none transition-all appearance-none shadow-sm dark:shadow-none"
                                    >
                                        <option value="9">Grade 9</option>
                                        <option value="10">Grade 10</option>
                                        <option value="11">Grade 11</option>
                                        <option value="12">Grade 12</option>
                                    </select>
                                </div>

                                <div>
                                    <label class="block text-slate-600 dark:text-slate-500 text-[10px] font-black uppercase tracking-[0.3em] mb-3 ml-1" id="white">WhatsApp / Phone</label>
                                    <input 
                                        type="tel" 
                                        name="phone" 
                                        required 
                                        placeholder="+251..." 
                                        class="w-full bg-white dark:bg-slate-800/30 border border-slate-200 dark:border-slate-800 rounded-2xl px-6 py-5 text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-slate-700 focus:border-emerald-500/50 outline-none transition-all shadow-sm dark:shadow-none" 
                                    />
                                </div>
                            </div>
                        </div>

                        <button 
                            type="submit" 
                            id="submit-btn"
                            class="mt-4 w-full py-6 bg-emerald-600 hover:bg-emerald-500 text-white font-black rounded-2xl transition-all uppercase tracking-[0.2em] shadow-xl shadow-emerald-900/20 active:scale-[0.98]"
                        >
                            Submit Application
                        </button>
                    </form>

                    <script>
                        // Import the Firebase logic we defined earlier
                        import { registerStudent } from "../lib/firebase";

                        const form = document.getElementById('application-form');
                        const btn = document.getElementById('submit-btn');
                        const errBox = document.getElementById('error-message');

                        form.addEventListener('submit', async (e) => {
                            e.preventDefault();
                            
                            // UI Loading State
                            btn.innerText = "VERIFYING...";
                            btn.style.opacity = "0.5";
                            btn.disabled = true;
                            errBox.classList.add('hidden');

                            const formData = new FormData(form);
                            const studentData = {
                                fullName: formData.get('name'),
                                course: formData.get('course'),
                                grade: formData.get('grade'),
                                phone: formData.get('phone')
                            };

                            try {
                                // Call the Firebase registration function
                                await registerStudent(studentData);
                                
                                // If successful, redirect
                                window.location.href = "/success";
                                
                            } catch (error) {
                                // Handle errors (Duplicate name or Network)
                                btn.style.opacity = "1";
                                btn.disabled = false;
                                btn.innerText = "Submit Application";
                                
                                errBox.classList.remove('hidden');
                                
                                if (error.message === "ALREADY_BOOKED") {
                                    errBox.innerText = "This name is already registered. Please contact the office if you need to make changes.";
                                } else {
                                    errBox.innerText = "Network error. Check your connection and try again.";
                                    console.error(error);
                                }
                            }
                        });
                    </script>
                </div>
            </div>
        </div>
    </section>

