---
import '../styles/global.css';
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <title>Registration Confirmed | Winter Code Lab</title>
    </head>
    <body class="bg-[#020617] text-slate-200 font-sans flex items-center justify-center min-h-screen p-8">
        
        <main class="max-w-xl w-full text-center space-y-8">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-emerald-500/10 rounded-full border border-emerald-500/20 text-emerald-500 animate-pulse">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
            </div>

            <div class="space-y-4">
                <h1 class="text-4xl font-black text-white tracking-tight">Registration Booked!</h1>
                <p class="text-slate-400">Your digital spot in the 2026 Winter Session is temporarily held. Use the number below to finalize your admission.</p>
            </div>

            <div class="bg-[#0f172a] border-2 border-dashed border-slate-800 p-10 rounded-3xl shadow-2xl relative overflow-hidden">
                <div class="absolute -left-4 top-1/2 -translate-y-1/2 w-8 h-8 bg-[#020617] rounded-full"></div>
                <div class="absolute -right-4 top-1/2 -translate-y-1/2 w-8 h-8 bg-[#020617] rounded-full"></div>
                
                <label class="block text-[10px] font-bold text-emerald-500 uppercase tracking-[0.3em] mb-4">Lab Entrance Number</label>
                <div id="entrance-number" class="text-6xl md:text-7xl font-mono font-black text-white tracking-tighter mb-4">
                    ---
                </div>
                <p class="text-xs text-slate-500 italic">Valid for 48 Hours</p>
            </div>

            <div class="bg-slate-900/40 p-6 rounded-2xl border border-slate-800 text-left space-y-4">
                <h3 class="text-white font-bold text-sm uppercase tracking-widest flex items-center gap-2">
                    <span class="w-2 h-2 bg-emerald-500 rounded-full"></span> Next Steps:
                </h3>
                <ul class="text-sm text-slate-400 space-y-3">
                    <li class="flex gap-3">
                        <span class="text-emerald-500 font-bold">1.</span> 
                        <span>Take a <b>screenshot</b> of this screen now.</span>
                    </li>
                    <li class="flex gap-3">
                        <span class="text-emerald-500 font-bold">2.</span> 
                        <span>Visit the <b>Comboni Office</b> and show your Entrance Number.</span>
                    </li>
                    <li class="flex gap-3">
                        <span class="text-emerald-500 font-bold">3.</span> 
                        <span>Pay the lab fee to receive your <b>Official Winter Slip</b>.</span>
                    </li>
                </ul>
            </div>

            <a href="/" class="inline-block text-slate-500 hover:text-emerald-400 text-sm font-medium transition-colors">
                ← Back to Homepage
            </a>
        </main>

        <script>
            // Logic to generate the Entrance Number
            function generateID() {
                const prefix = "WCL";
                const year = "26";
                const random = Math.floor(1000 + Math.random() * 9000);
                return `${prefix}-${year}-${random}`;
            }

            // Set the ID when the page loads
            const display = document.getElementById('entrance-number');
            if (display) {
                display.innerText = generateID();
            }
        </script>

    </body>
</html>